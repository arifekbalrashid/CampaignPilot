# Database (use sqlite for local dev, mysql for production)
DATABASE_URL=sqlite+aiosqlite:///./campaignpilot.db
# DATABASE_URL=mysql+aiomysql://cpuser:cppassword@localhost:3306/campaignpilot

# AI
GEMINI_API_KEY=your-gemini-api-key-here

# Google OAuth (get from https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Channel Service
CHANNEL_SERVICE_URL=http://localhost:8001

# CRM (used by channel service for callbacks)
CRM_CALLBACK_URL=http://localhost:8000/api/receipts

# Server
HOST=0.0.0.0
PORT=8000

# CORS Origins
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:3000
